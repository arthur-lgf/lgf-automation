<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{ title }}</title>
  <style>{{ css | safe }}</style>
</head>
<body>
  <table id="report-table" class="report">
    {% if header %}
    <thead>
      <tr>
        {% for cell in header %}
        <th>{{ cell }}</th>
        {% endfor %}
      </tr>
    </thead>
    {% endif %}
    <tbody>
      {% for row in body %}
      <tr>
        {% for cell in row %}
        <td class="{{ 'amount' if cell.is_amount else 'text' }}">{{ cell.value }}</td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</body>
</html>
