# Path to your Google service-account JSON
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# Slack bot token (xoxb-...) with files:write and chat:write scopes
SLACK_BOT_TOKEN=

# Slack channel ID (e.g. C0123ABCDEF), not the channel name
SLACK_CHANNEL_ID=C0B4XFQRQ4F

# Optional defaults for smoke testing
DEFAULT_SPREADSHEET_ID=12glaANnP2BsQfH_kHfRlzA40JdWAU-PJgDT-56yRV8k
DEFAULT_GID=170384010
DEFAULT_RANGE=B1:J25

# Playwright viewport (px)
VIEWPORT_WIDTH=1400
VIEWPORT_HEIGHT=900

# --- Approvals report: GET /reports/approvals ---
# Channel the daily "APPROVALS REPORT" is posted to. The LGF bot (SLACK_BOT_TOKEN)
# must be a MEMBER of this channel. If blank, falls back to SLACK_CHANNEL_ID.
APPROVALS_CHANNEL_ID=C0B4XFQRQ4F
# Source sheet (APPTRACK 3.0, tab APPS). Defaults are baked into the app; override only if it moves.
APPROVALS_SPREADSHEET_ID=1Tc8x72ys7_oWQnUm03LWa-KHgHMXmX2HGH7gz1-xC_c
APPROVALS_GID=340057391
APPROVALS_RANGE=A1:L
# Time zone used to compute "today" when ?date= is not supplied.
REPORT_TZ=America/New_York
# 0-based column indices: date_approved,client,bank,amount,invoice_sent,rep  (B,E,G,I,K,L)
APPROVALS_COLS=1,4,6,8,10,11
